# Pocket Agent Configuration
#
# Place this file at:
#   Development: project root (.env)
#   Packaged app: ~/.pocket-agent/.env
#
# Server connection settings are ONLY configured here (not in Settings UI).

# ── Server connection ──────────────────────────────────────
# Hermes gateway URL (required)
API_SERVER=http://localhost:8642

# API key for authentication (leave empty for no auth)
API_SERVER_KEY=

# Agent name — routes to openclaw/{agent} if set (e.g. "xingyin")
API_AGENT=xingyin

# ── Optional features ──────────────────────────────────────
# Enable local command execution ([CMD:...] tags in LLM responses)
# ENABLE_LOCAL_COMMANDS=true

# ── Binary paths ───────────────────────────────────────────
# Edge TTS binary path (default: auto-resolved from PATH)
# EDGE_TTS_BIN=/path/to/edge-tts

# Python interpreter with faster_whisper installed (default: system python3)
# STT_PYTHON=/path/to/python3
