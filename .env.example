# Pocket Agent Configuration
# Copy this file to .env and fill in your values

# API Server URL — Hermes (default) or OpenClaw
# Hermes: http://localhost:8642
# OpenClaw: http://localhost:18789
API_SERVER=http://localhost:8642

# API Server key
# Hermes: from ~/.hermes/config.yaml -> api_server.key
# OpenClaw: from openclaw.json -> gateway.auth.token
API_SERVER_KEY=your-api-server-key-here

# OpenClaw only: agent to route to (e.g. main, zhenyan, qingyin)
# Leave unset for Hermes mode
# API_AGENT=main

# Edge TTS binary path (install: pip install edge-tts)
EDGE_TTS_BIN=/path/to/edge-tts

# Python interpreter with faster_whisper installed
STT_PYTHON=/path/to/python3

# Enable local command execution from LLM responses (e.g., [CMD:open -a "Chrome"])
# WARNING: This allows the LLM to execute arbitrary shell commands on your machine.
# Only enable if you trust the backend and understand the security implications.
# Default: false
ENABLE_LOCAL_COMMANDS=false
