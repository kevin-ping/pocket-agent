#!/usr/bin/env python3
"""stt-helper: uses faster_whisper for local STT. Returns JSON with text + detected language."""
import sys
import json
from faster_whisper import WhisperModel

if len(sys.argv) != 2:
    print("Usage: stt-helper <wav_file>", file=sys.stderr)
    sys.exit(1)

wav_path = sys.argv[1]

import time
t0 = time.time()

try:
    print(f"[stt] loading model...", file=sys.stderr, flush=True)
    model = WhisperModel("small", device="cpu", compute_type="int8")
    print(f"[stt] model loaded ({time.time()-t0:.1f}s), transcribing...", file=sys.stderr, flush=True)
    t1 = time.time()
    segments, info = model.transcribe(wav_path, beam_size=5)
    text = " ".join(seg.text.strip() for seg in segments).strip()
    detected_lang = info.language
    print(f"[stt] done ({time.time()-t1:.1f}s) lang={detected_lang}", file=sys.stderr, flush=True)

    if text:
        result = {"text": text, "language": detected_lang}
        print(json.dumps(result, ensure_ascii=False))
    else:
        print("Empty result", file=sys.stderr)
        sys.exit(1)
except Exception as e:
    print(str(e), file=sys.stderr)
    sys.exit(1)
